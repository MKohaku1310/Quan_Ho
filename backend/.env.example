# Quan Ho Bac Ninh - Backend Configuration Template
# Copy this file to .env and fill in the values

# Database Configuration
# Default uses SQLite: sqlite:///./quan_ho.db
# MySQL example: mysql+pymysql://user:password@localhost:3306/quan_ho
DATABASE_URL=sqlite:///./quan_ho.db

# Security
# Run 'openssl rand -hex 32' to generate a real secret key
SECRET_KEY=yoursecretkeyhere_change_me_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# CORS (Optional, comma separated list of origins)
# CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
